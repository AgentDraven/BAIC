# BAIC local secrets ONLY — copy to .env.local (gitignored)
# Non-secret configuration belongs in cfg/config.json (MERIT §III — cfg vs secrets).

# MERIT operator (merit.ps1)
MERIT_PERSONA=AgentDraven
# GIT_USER_EMAIL / GITHUB_TOKEN may live in persona env (HumanBala/env/AgentDraven/.env.local)

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Microsoft Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Amazon Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Oracle OCI
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=

# Consumer frontends
CURSOR_API_TOKEN=
GITHUB_TOKEN=
GOOGLE_ONE_CLIENT_ID=
