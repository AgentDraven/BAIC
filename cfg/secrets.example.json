      "private_key_path": "<Path to OCI private key PEM>"
    },
    "cursor_pro": {
      "api_token": "<Cursor Pro API token if applicable>"
    },
    "github_copilot": {
      "github_token": "<GitHub token for Copilot API>"
    },
